OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
HOST=127.0.0.1
PORT=8787
HOSTED_MODE=false
APP_USERNAME=tushar
APP_PASSWORD=
DATABASE_PATH=data/job_agent.db
JOB_SEARCH_QUERY=software engineer
JOB_SEARCH_QUERIES=software engineer,backend engineer,full stack engineer,platform engineer,AI engineer,machine learning engineer,applications engineer,field applications engineer,solutions engineer,power electronics engineer,analog hardware engineer,PCB design engineer,hardware validation engineer,firmware engineer,FPGA engineer,FPGA verification engineer,SoC design engineer,ASIC RTL engineer,design verification engineer,SerDes validation engineer,mixed signal validation engineer,game developer,unity developer,gameplay engineer,technical game designer,XR engineer
JOB_SEARCH_REGIONS=Worldwide remote,India,Canada,United Kingdom,Australia,Europe,Singapore,United States
JOB_SEARCH_LIMIT=25
JOB_SYNC_INTERVAL_MINUTES=360
AUTO_TAILOR=true
MAX_TAILORS_PER_CYCLE=5
MIN_FIT_SCORE=55
ENABLE_OPENAI_JOB_SEARCH=true
ENABLE_YC_JOB_SEARCH=true
WEB_SEARCH_JOB_LIMIT=20
WEB_SEARCH_PER_LANE_LIMIT=10
# Live submission is intentionally unavailable until a site-specific adapter exists.
ENABLE_LIVE_APPLICATIONS=false
ARTIFACT_DIR=data/packages
CANDIDATE_CONTEXT_PATH=profile/candidate_context.json
RESUME_TEMPLATE_PATH=profile/resume_template.tex

# Autonomous ATS submission. AUTO_SUBMIT is the master toggle for the unattended
# decide->prepare->submit step in the worker cycle. Each adapter also needs its own
# ENABLE_LIVE_* flag (plus ENABLE_LIVE_APPLICATIONS above) before it will actually click
# Submit; until then every run is a dry run that only writes a screenshot + field-dump log.
AUTO_SUBMIT=false
AUTO_SUBMIT_MIN_FIT_SCORE=70
ENABLE_LIVE_GREENHOUSE=false
ENABLE_LIVE_LEVER=false
MAX_APPLICATIONS_PER_CYCLE=25

# YC company sourcing + cold-outreach. AUTO_OUTREACH is the master toggle for the
# unattended sync->draft->send step. ENABLE_LIVE_OUTREACH gates real SMTP sends; until
# set, outreach emails are written as .eml previews instead of being sent.
AUTO_OUTREACH=false
ENABLE_LIVE_OUTREACH=false
YC_MIN_BATCH_YEAR=2005
YC_OUTREACH_MIN_FIT_SCORE=15
YC_ENRICH_MAX_COMPANIES=100
MAX_OUTREACH_PER_CYCLE=25
STARTUP_MIN_FIT_SCORE=15
STARTUP_ENRICH_MAX_COMPANIES=100
STARTUP_SEC_FORM_D_DAYS=30
STARTUP_SEC_FORM_D_LIMIT=200
# Optional comma-separated public VC/accelerator portfolio URLs to crawl lightly.
STARTUP_PORTFOLIO_URLS=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
